# LangWIKI service
PORT=3100
NODE_ENV=development
CORS_ORIGIN=*
LOG_LEVEL=info

# storage
LANGWIKI_DATA_DIR=./data
LANGWIKI_USERS_DIR=./data/users

# LLM 配置
# 支持的预设模型:
#   deepseek/deepseek-chat       — DeepSeek Chat（国内可用，推荐）
#   deepseek/deepseek-reasoner   — DeepSeek R1 推理模型
#   openai/gpt-4o                — OpenAI GPT-4o
#   openai/gpt-4o-mini           — OpenAI GPT-4o-mini
#   qwen/qwen-plus               — 通义千问
#   claude-sonnet-4              — Anthropic Claude Sonnet 4
#   claude-3.5-haiku             — Anthropic Claude 3.5 Haiku
#   gemini-flash-latest          — Google Gemini
#   gemini-2.0-flash             — Google Gemini 2.0 Flash
#   ollama/qwen2.5:7b            — Ollama 本地（离线）
#   ollama/llama3.2              — Ollama 本地（离线）
LLM_MODEL=deepseek/deepseek-chat
LLM_TEMPERATURE=0.3

# API Keys（根据选择的模型设置对应的 key）
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Ollama 无需 API Key（本地运行）
